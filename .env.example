# ==========================================
# ENV TEMPLATE INSTRUCTIONS FOR THE TEAM
# ==========================================
# 1. Rename this file from ".env.example" to exactly ".env"
# 2. To use your own MongoDB cloud database, paste your connection string below after the "=" sign.
# 3. If you want to use a local MongoDB installation instead of the cloud, you can just leave MONGODB_URI blank!
# 
# Example: 
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/pctracker?retryWrites=true&w=majority

MONGODB_URI=

# You can leave this SESSION_SECRET alone, it just secures the login cookies locally
SESSION_SECRET=pctracker-super-secret-key-2026
